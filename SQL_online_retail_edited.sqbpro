<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="SQL_online_retail_edited.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="1"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1319"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="rfm_results" custom_title="0" dock_id="1" table="4,11:mainrfm_results"/><dock_state state="000000ff00000000fd00000001000000020000043c000002b6fc0100000001fb000000160064006f0063006b00420072006f007700730065003101000000000000043c0000013900ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="online_retail" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="62"/><column index="2" value="67"/><column index="3" value="280"/><column index="4" value="56"/><column index="5" value="124"/><column index="6" value="85"/><column index="7" value="46"/><column index="8" value="46"/><column index="9" value="75"/><column index="10" value="117"/><column index="11" value="54"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="rfm_results" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="62"/><column index="2" value="75"/><column index="3" value="280"/><column index="4" value="85"/><column index="5" value="163"/><column index="6" value="55"/><column index="7" value="54"/><column index="8" value="66"/><column index="9" value="53"/><column index="10" value="70"/><column index="11" value="56"/><column index="12" value="132"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE rfm_results AS

SELECT
	*,
	CASE
	WHEN R_Score = 5 AND F_Score = 5 AND M_Score = 5 THEN &quot;Valued Customer&quot;      	  -- ลูกค้าชั้นดี
		WHEN R_Score = 5 AND F_Score &lt;=2 THEN &quot;New Customer&quot;                          -- ลูกค้าใหม่ เพิ่งมาซื้อไม่กี่ครั้ง
		WHEN R_Score &lt;=2 AND F_Score = 5 AND M_Score &gt;=4 THEN &quot;Lost Valued Customer&quot;  -- เคยเป็นลูกค้าชั้นดี แค่ขาดการกลับมาซื้อซ้ำ
		ELSE &quot;General Customer&quot;	
	END AS Customer_Segment
FROM
	(
	SELECT
		Invoice,
		CustomerID,
		Description,
		Date,
		Country,
		Recency,
		NTILE(5) OVER(ORDER BY Recency DESC) AS R_Score,
		Frequency,
		NTILE(5) OVER(ORDER BY Frequency ASC) AS F_Score,
		Monetory,
		NTILE(5) OVER(ORDER BY Monetory ASC) AS M_Score
	FROM
		(
		SELECT
			Invoice,
			CustomerID,
			Description,
			Date,
			Country,
			JULIANDAY(&quot;2011-12-10&quot;) - JULIANDAY(MAX(REPLACE(Date, &quot;/&quot;, &quot;-&quot;))) AS Recency,
			COUNT(DISTINCT Invoice) AS Frequency,
			SUM(total) AS Monetory
		FROM online_retail
		WHERE CustomerID != &quot;Unknown&quot;
		GROUP BY CustomerID
		)
	ORDER BY M_Score DESC, Monetory DESC
	)
ORDER BY Customer_Segment;</sql><current_tab id="0"/></tab_sql></sqlb_project>
